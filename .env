NEXT_PUBLIC_WEB_VERSION="1.0.1-latest"

NEXT_PUBLIC_API_URL="https://fitflow.shopbluewolf.com"

# WEBSITE URL
NEXT_PUBLIC_WEB_URL="https://fitflow.shopbluewolf.com"

# API ENDPOINT (Do not change)
NEXT_PUBLIC_END_POINT="api"

# WEBSITE NAME
NEXT_PUBLIC_WEB_NAME="Fit Flow"

# # VAPID KEY (This key you get from firebase and steps given in doc)
NEXT_PUBLIC_VAPID_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# FIREBASE (Compulsory configure this settings otherwise login is not working)
NEXT_PUBLIC_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_AUTH_DOMAIN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_PROJECT_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_STORAGE_BUCKET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_MESSAGING_SENDER_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_APP_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_MEASUREMENT_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# DEFAULT META TAGS (This is for seo metadata)
NEXT_PUBLIC_TITLE="Fit Flow — Smart Fitness Management for Trainers, Coaches & Facilities"
NEXT_PUBLIC_DESCRIPTION="Fit Flow is the all-in-one fitness management platform that helps personal trainers, fitness coaches, physical therapists, wellness coaches, and gym facilities manage clients, track health metrics, build programs, and grow their business."
NEXT_PUBLIC_kEYWORDS="fitness management platform, personal trainer software, gym management app, client management for trainers, health metrics tracking, Apple Watch fitness app, trainer management system, fitness coaching software, physical therapy client management, wellness coach platform, Fit Flow"

# Loading Min (Do not change)
NEXT_PUBLIC_LOAD_MIN=5
