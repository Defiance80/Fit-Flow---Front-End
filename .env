NEXT_PUBLIC_WEB_VERSION="1.0.1-latest"

NEXT_PUBLIC_API_URL="https://elms.wrteam.me" # do not add '/' at the end

# WEBSITE URL
NEXT_PUBLIC_WEB_URL="https://elms-web.wrteam.me" # do not add '/' at the endj

# API ENDPOINT (Do not change)
NEXT_PUBLIC_END_POINT="api"

# WEBSITE NAME
NEXT_PUBLIC_WEB_NAME="E-LMS" # This field is must do not leave it as blank

# # VAPID KEY (This key you get from firebase and steps given in doc)
NEXT_PUBLIC_VAPID_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# FIREBASE (Compulsory configure this settings otherwise login is not working)
NEXT_PUBLIC_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_AUTH_DOMAIN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_PROJECT_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_STORAGE_BUCKET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_MESSAGING_SENDER_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_APP_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_MEASUREMENT_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# DEFAULT META TAGS (This is for seo metadata)
NEXT_PUBLIC_TITLE="E-LMS - Online Learning Management System for Courses, Training & Skill Development"
NEXT_PUBLIC_DESCRIPTION="E-LMS is a modern learning management system that helps individuals, educators, and organizations create, manage, and sell online courses. Learn anytime, anywhere with expert instructors and interactive content."
NEXT_PUBLIC_kEYWORDS="E-LMS, online learning, learning management system, LMS platform, sell courses online, e-learning platform, virtual training, instructor-led courses, student portal, course marketplace, Udemy alternative, online education, skill development, video courses, remote learning"

# Loading Min (Do not change)
NEXT_PUBLIC_LOAD_MIN=5